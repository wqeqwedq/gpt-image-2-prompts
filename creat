import { createClient } from 'https://esm.sh/@supabase/supabase-js@2.39.3'

const supabaseUrl = Deno.env.get('SUPABASE_URL') ?? ''
const supabaseKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? ''
const apiMartKey = Deno.env.get('API_MART_KEY') ?? ''

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
}

const resolutionCostMap: Record<string, number> = {
  '1k': 1,
  '2k': 2,
  '4k': 3,
}

const supported4kAspectRatios = new Set(['16:9', '9:16', '2:1', '1:2', '21:9', '9:21'])

interface CreateImageRequest {
  prompt: string
  resolution?: string
  aspectRatio?: string
  invitationCode: string
  imageUrls?: string[]
}

/**
 * 检查邀请码额度
 */
async function checkQuota(supabase: any, invitationCode: string, requiredQuota: number) {
  const { data, error } = await supabase
    .from('invitation_codes')
    .select('generation_quota, used_count, is_active')
    .eq('code', invitationCode)
    .single()

  if (error || !data) {
    throw new Error('邀请码无效')
  }

  if (!data.is_active) {
    throw new Error('邀请码已被禁用')
  }

  const remaining = data.generation_quota - data.used_count
  if (remaining < requiredQuota) {
    throw new Error(`额度不足，当前剩余 ${remaining} 次，需要 ${requiredQuota} 次`)
  }

  return {
    success: true,
    remaining,
    requiredQuota,
    quota: data.generation_quota,
    used: data.used_count
  }
}

/**
 * 扣除额度
 */
async function useQuota(supabase: any, invitationCode: string, requiredQuota: number) {
  const rpcPayloadCandidates = [
    { code_to_use: invitationCode, quota_to_use: requiredQuota },
    { code_to_use: invitationCode, times_to_use: requiredQuota },
    { code_to_use: invitationCode, amount_to_use: requiredQuota },
    { code_to_use: invitationCode, amount: requiredQuota },
  ]

  let lastError: any = null

  for (const payload of rpcPayloadCandidates) {
    const { data, error } = await supabase
      .rpc('use_generation_quota', payload)

    if (error) {
      lastError = error
      continue
    }

    if (!data || !data.success) {
      throw new Error(data?.message || '扣除额度失败')
    }

    return data
  }

  throw new Error('扣除额度失败: ' + (lastError?.message || 'RPC 参数不匹配'))
}

/**
 * 提交生图任务到 API Mart
 */
async function submitGenerationTask(
  prompt: string,
  resolution: string,
  aspectRatio: string,
  imageUrls?: string[]
) {
  const payload: any = {
    model: 'gpt-image-2',
    prompt: prompt,
    n: 1,
    size: aspectRatio,
    resolution: resolution
  }

  if (imageUrls && imageUrls.length > 0) {
    payload.image_urls = imageUrls
  }

  const response = await fetch('https://api.apimart.ai/v1/images/generations', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${apiMartKey}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(payload)
  })

  const result = await response.json()

  if (!response.ok) {
    throw new Error(result.error?.message || '提交生图任务失败')
  }

  if (result.code !== 200 || !result.data || !result.data[0]?.task_id) {
    throw new Error('提交生图任务失败：未返回任务ID')
  }

  return result.data[0].task_id
}

Deno.serve(async (req) => {
  // 处理 CORS
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    // 只接受 POST 请求
    if (req.method !== 'POST') {
      return new Response(
        JSON.stringify({ success: false, error: '只支持 POST 请求' }),
        { status: 405, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    // 解析请求体
    const {
      prompt,
      resolution = '1k',
      aspectRatio = '1:1',
      invitationCode,
      imageUrls = []
    }: CreateImageRequest = await req.json()

    // 参数验证
    if (!prompt) {
      return new Response(
        JSON.stringify({ success: false, error: '缺少提示词' }),
        { status: 400, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    if (!invitationCode) {
      return new Response(
        JSON.stringify({ success: false, error: '缺少邀请码' }),
        { status: 400, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    const requiredQuota = resolutionCostMap[resolution]
    if (!requiredQuota) {
      return new Response(
        JSON.stringify({ success: false, error: '分辨率仅支持 1k/2k/4k' }),
        { status: 400, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    if (resolution === '4k' && !supported4kAspectRatios.has(aspectRatio)) {
      return new Response(
        JSON.stringify({ success: false, error: '4k 仅支持 16:9 / 9:16 / 2:1 / 1:2 / 21:9 / 9:21' }),
        { status: 400, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    console.log('开始处理生图请求:', {
      prompt: prompt.substring(0, 50),
      resolution,
      aspectRatio,
      invitationCode,
      requiredQuota
    })

    // 创建 Supabase 客户端
    const supabase = createClient(supabaseUrl, supabaseKey)

    // 1. 检查额度
    console.log('检查额度...')
    const quotaCheck = await checkQuota(supabase, invitationCode, requiredQuota)
    console.log('额度检查通过，剩余:', quotaCheck.remaining, '本次需消耗:', requiredQuota)

    // 2. 提交生图任务到 API
    console.log('提交生图任务到 API...')
    const apiTaskId = await submitGenerationTask(prompt, resolution, aspectRatio, imageUrls)
    console.log('任务已提交，API taskId:', apiTaskId)

    // 3. 扣除额度
    console.log('扣除额度...')
    const quotaResult = await useQuota(supabase, invitationCode, requiredQuota)
    console.log('额度扣除成功，剩余:', quotaResult.remaining)

    // 4. 创建任务记录到数据库
    console.log('创建任务记录到数据库...')
    const { data: taskData, error: taskError } = await supabase
      .from('generation_tasks')
      .insert({
        invitation_code: invitationCode,
        prompt: prompt,
        resolution: resolution,
        aspect_ratio: aspectRatio,
        image_urls: imageUrls,
        api_task_id: apiTaskId,
        status: 'submitted'
      })
      .select()
      .single()

    if (taskError || !taskData) {
      console.error('创建任务记录失败:', taskError)
      return new Response(
        JSON.stringify({ success: false, error: '任务已提交但记录入库失败，请联系管理员排查' }),
        { status: 500, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    console.log('任务记录创建成功，任务ID:', taskData.id)

    // 5. 返回结果（不等待任务完成，由 Cron 定时检查）
    return new Response(
      JSON.stringify({
        success: true,
        message: '任务已提交，正在生成中...',
        taskId: apiTaskId,
        dbTaskId: taskData.id,
        remainingQuota: quotaResult.remaining
      }),
      { headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
    )

  } catch (error) {
    console.error('生图失败:', error)
    const message = error instanceof Error ? error.message : '生图失败，请稍后重试'
    return new Response(
      JSON.stringify({
        success: false,
        error: message
      }),
      { status: 500, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
    )
  }
})
