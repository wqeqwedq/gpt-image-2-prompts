import { createClient } from 'https://esm.sh/@supabase/supabase-js@2.39.3'

const supabaseUrl = Deno.env.get('SUPABASE_URL') ?? ''
const supabaseKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? ''
const apiMartKey = Deno.env.get('API_MART_KEY') ?? ''

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
}

/**
 * 查询任务状态（单个任务）
 */
async function checkTaskStatus(apiTaskId: string) {
  const response = await fetch(`https://api.apimart.ai/v1/tasks/${apiTaskId}`, {
    headers: {
      'Authorization': `Bearer ${apiMartKey}`
    }
  })

  const result = await response.json()

  if (!response.ok) {
    throw new Error('查询任务状态失败')
  }

  return result.data
}

/**
 * 批量查询任务状态
 */
async function batchCheckTasks(apiTaskIds: string[]) {
  const response = await fetch('https://api.apimart.ai/v1/tasks/batch', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${apiMartKey}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      task_ids: apiTaskIds
    })
  })

  const result = await response.json()

  if (!response.ok) {
    throw new Error('批量查询任务状态失败')
  }

  return result.data
}

function isValidTaskStatusPayload(taskStatus: any) {
  return !!taskStatus && typeof taskStatus.id === 'string' && typeof taskStatus.status === 'string'
}

async function updateTaskStatus(supabase: any, taskId: string, updateData: any) {
  const { error } = await supabase
    .from('generation_tasks')
    .update(updateData)
    .eq('id', taskId)

  if (error) {
    console.error('更新任务失败:', error)
    throw new Error('更新任务失败: ' + error.message)
  }
}

/**
 * 获取 API 任务 ID 到数据库任务 ID 的映射
 */
async function getTaskMapping(supabase: any, apiTaskIds: string[]) {
  const { data, error } = await supabase
    .from('generation_tasks')
    .select('id, api_task_id')
    .in('api_task_id', apiTaskIds)

  if (error) {
    throw new Error('查询任务映射失败: ' + error.message)
  }

  // 创建映射：api_task_id -> db_task_id
  const mapping: Record<string, string> = {}
  data?.forEach((task: any) => {
    mapping[task.api_task_id] = task.id
  })

  return mapping
}

Deno.serve(async (req) => {
  // 处理 CORS
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    console.log('开始检查任务状态...')

    // 创建 Supabase 客户端
    const supabase = createClient(supabaseUrl, supabaseKey)

    // 1. 查询所有待处理的任务（submitted 或 processing）
    console.log('查询待处理任务...')
    const { data: pendingTasks, error: queryError } = await supabase
      .from('generation_tasks')
      .select('id, api_task_id, status, created_at')
      .in('status', ['submitted', 'processing'])
      .order('created_at', { ascending: true })
      .limit(50)

    if (queryError) {
      throw new Error('查询待处理任务失败: ' + queryError.message)
    }

    if (!pendingTasks || pendingTasks.length === 0) {
      console.log('没有待处理的任务')
      return new Response(
        JSON.stringify({
          success: true,
          message: '没有待处理的任务',
          checkedCount: 0
        }),
        { headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    console.log(`找到 ${pendingTasks.length} 个待处理任务`)

    // 2. 提取 API 任务 ID
    const apiTaskIds = pendingTasks.map(task => task.api_task_id).filter(Boolean)

    if (apiTaskIds.length === 0) {
      console.log('没有有效的 API 任务 ID')
      return new Response(
        JSON.stringify({
          success: true,
          message: '没有有效的 API 任务 ID',
          checkedCount: 0
        }),
        { headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
      )
    }

    // 3. 批量查询任务状态
    console.log('批量查询任务状态...')
    let taskStatuses
    try {
      taskStatuses = await batchCheckTasks(apiTaskIds)
    } catch (error) {
      // 如果批量查询失败，尝试单个查询
      console.log('批量查询失败，尝试单个查询...')
      taskStatuses = []
      for (const apiTaskId of apiTaskIds) {
        try {
          const status = await checkTaskStatus(apiTaskId)
          taskStatuses.push(status)
        } catch (error) {
          console.error(`查询任务 ${apiTaskId} 失败:`, error)
        }
      }
    }

    console.log(`查询到 ${taskStatuses.length} 个任务状态`)

    // 4. 获取任务映射
    const taskMapping = await getTaskMapping(supabase, apiTaskIds)

    // 5. 更新任务状态
    let completedCount = 0
    let failedCount = 0
    let processingCount = 0
    let invalidPayloadCount = 0

    for (const taskStatus of taskStatuses) {
      if (!isValidTaskStatusPayload(taskStatus)) {
        invalidPayloadCount++
        console.warn('任务状态载荷无效，已跳过:', taskStatus)
        continue
      }

      const apiTaskId = taskStatus.id
      const dbTaskId = taskMapping[apiTaskId]
      const status = taskStatus.status
      const progress = typeof taskStatus.progress === 'number' ? taskStatus.progress : 0

      if (!dbTaskId) {
        console.warn(`找不到 API 任务 ${apiTaskId} 对应的数据库任务`)
        continue
      }

      console.log(`任务 ${apiTaskId}: 状态=${status}, 进度=${progress}%`)

      if (status === 'completed') {
        // 任务完成
        const imageUrl = taskStatus.result?.images?.[0]?.url?.[0]
        if (!imageUrl) {
          const errorMessage = '任务已完成但未找到图片 URL'
          console.error(`任务 ${apiTaskId} ${errorMessage}`)

          await updateTaskStatus(supabase, dbTaskId, {
            status: 'failed',
            error_message: errorMessage,
            completed_at: new Date().toISOString()
          })

          failedCount++
          continue
        }

        await updateTaskStatus(supabase, dbTaskId, {
          status: 'completed',
          image_url: imageUrl,
          progress: 100,
          actual_time: taskStatus.actual_time,
          completed_at: new Date().toISOString()
        })

        completedCount++
        console.log(`任务 ${apiTaskId} 已完成，图片 URL: ${imageUrl}`)

      } else if (status === 'failed') {
        // 任务失败
        const errorMessage = taskStatus.error?.message || '生图任务失败'

        await updateTaskStatus(supabase, dbTaskId, {
          status: 'failed',
          error_message: errorMessage,
          completed_at: new Date().toISOString()
        })

        failedCount++
        console.log(`任务 ${apiTaskId} 失败: ${errorMessage}`)

      } else if (status === 'processing' || status === 'submitted') {
        // 任务处理中
        await updateTaskStatus(supabase, dbTaskId, {
          status: status,
          progress: progress
        })

        processingCount++
        console.log(`任务 ${apiTaskId} 处理中，进度: ${progress}%`)
      }
    }

    // 6. 返回结果
    console.log(`检查完成: ${completedCount} 个完成, ${failedCount} 个失败, ${processingCount} 个处理中, ${invalidPayloadCount} 个无效载荷`)

    return new Response(
      JSON.stringify({
        success: true,
        message: '检查完成',
        checkedCount: pendingTasks.length,
        completedCount: completedCount,
        failedCount: failedCount,
        processingCount: processingCount,
        invalidPayloadCount: invalidPayloadCount
      }),
      { headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
    )

  } catch (error) {
    console.error('检查任务状态失败:', error)
    return new Response(
      JSON.stringify({
        success: false,
        error: error.message || '检查任务状态失败'
      }),
      { status: 500, headers: { ...corsHeaders, 'Content-Type': 'application/json' } }
    )
  }
})